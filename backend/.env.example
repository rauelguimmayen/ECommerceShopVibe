# ── Local Development ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# On Render, set these as Environment Variables in the dashboard instead.

PORT=5000
MONGO_URI=mongodb://localhost:27017/shopvibe
JWT_SECRET=replace_this_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d
NODE_ENV=development

# ── Google OAuth ──────────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/
# 2. Create a project → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 3. Application type: Web application
# 4. Authorised JavaScript origins: http://localhost:5000 (and your Render URL in production)
# 5. Copy the Client ID below (the Client Secret is NOT needed — we use the one-tap flow)
GOOGLE_CLIENT_ID=your_google_client_id_here

# ── Password Reset (SMTP) ──────────────────────────────────────────────────────
# Option A – Gmail (use an App Password, not your real password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your_app_password_here
#   SMTP_FROM=ShopVibe <you@gmail.com>
#
# Option B – Resend (free tier, great for Render):
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=resend
#   SMTP_PASS=re_your_api_key_here
#   SMTP_FROM=ShopVibe <onboarding@resend.dev>
#
# Option C – Mailtrap (dev/testing only, no real emails sent):
#   SMTP_HOST=sandbox.smtp.mailtrap.io
#   SMTP_PORT=2525
#   SMTP_USER=your_mailtrap_user
#   SMTP_PASS=your_mailtrap_pass
#   SMTP_FROM=ShopVibe <no-reply@shopvibe.com>


